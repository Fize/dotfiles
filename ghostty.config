# ====================
# 窗口与界面设置
# ====================

# 初始窗口行为
initial-window = true
# 退出行为
quit-after-last-window-closed = true
# 关闭调整大小的视觉覆
resize-overlay = never
# 启用平滑窗口调整
window-step-resize = false
# 自动平衡边距
window-padding-balance = true
# 直接关闭不提示
confirm-close-surface = true
# 记住窗口状态和位置
window-save-state = always

# ====================
# 外观与视觉效果
# ====================

# 浅色 GitHub Light Colorblind, 深色 Rose Pine Moon
#theme = light:GitHub Light Colorblind,dark:Rose Pine Moon
## 标准深色主题
theme = Rose Pine Moon
# 窗口标题栏跟随系统
window-theme = system
# macOS毛玻璃模糊效果
background-blur-radius = 20
window-padding-x = 20
window-padding-y = 2,10
 # 背景图片
background-image = ~/dotfiles/cat.png
# 背景图片透明度
background-image-opacity = 0.05
# 背景图片匹配方式
background-image-fit = stretch
# 背景透明度
background-opacity = 1

# ====================
# 字体与文本渲染
# ====================

# 主字体设置 (使用逗号分隔实现字体回退)
font-family = LXGW WenKai Mono
font-family = Cascadia Code NF
# 适中字号提升可读性
font-size = 15
# 中等字重
font-style = medium
# 粗体显示为亮色
bold-is-bright = true
# 禁用连字符(更适合终端)
font-feature = -calt

# ====================
# 光标与选区设置
# ====================

cursor-color = e5c07b
# 光标样式
cursor-style = block
# 禁用光标闪烁
cursor-style-blink = true
# 着色器
custom-shader = ~/dotfiles/cursor_blaze.glsl
custom-shader-animation = true

# 选择即复制到剪贴板
# copy-on-select = clipboard
# 自动修剪末尾空格
clipboard-trim-trailing-spaces = true

# ====================
# 鼠标与滚动行为
# ====================

# 双倍滚动速度
mouse-scroll-multiplier = 2
# 输入时隐藏鼠标
mouse-hide-while-typing = true

# ====================
# 自动更新与版本控制
# ====================

# 自动检测版本更新
auto-update = check
# 只更新稳定版
auto-update-channel = stable

# ====================
# Shell 与系统集成
# ====================

# 启用命令区块分隔功能
shell-integration-features = true

# ====================
# 快捷键绑定
# ====================

# keybind
keybind = super+left=previous_tab
keybind = super+right=next_tab

# 全局下拉终端
# keybind = global:ctrl+grave_accent=toggle_quick_terminal

# ====================
# 快捷键绑定
# ====================

#=== 下拉终端（Quake 风格） ===
# quick-terminal-position = top
# quick-terminal-screen = mouse
# quick-terminal-autohide = true
# quick-terminal-animation-duration = 0.15

##################################################
# macOS 专属优化设置
##################################################

# Option键作为Alt发送转义序列
macos-option-as-alt = true
# 透明标题栏
macos-titlebar-style = transparent
